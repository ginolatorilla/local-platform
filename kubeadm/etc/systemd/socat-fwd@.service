[Unit]
Description=Socat Local Port Forwarding Service for Port %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nobody
Group=nogroup
AmbientCapabilities=CAP_NET_BIND_SERVICE
ExecStart=/usr/local/bin/socat-fwd-nodeport %i 30000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target